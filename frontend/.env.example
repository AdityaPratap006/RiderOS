# Mappls map tile URL (use Mappls tile endpoint once you have a key)
VITE_MAPPLS_MAP_STYLE=https://maps.mappls.com/apis/maps/vector/v3/map?access_token=YOUR_ACCESS_TOKEN

# Supabase (public anon key — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
