PORT=4000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mappls (MapmyIndia) — routing, geocoding, map tiles
MAPPLS_API_KEY=your-mappls-api-key
MAPPLS_CLIENT_ID=your-mappls-client-id
MAPPLS_CLIENT_SECRET=your-mappls-client-secret
MAPPLS_TOKEN_AUTH_URL=the-mappls-token-auth-url
MAPPLS_STATIC_API_KEY=your-mappls-static-api-key

# Open-Meteo — no key needed, base URL only
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# LLM (GROQ) — for POI ranking in route planner
GROQ_API_KEY=your-groq-api-key

# Reddit — for ingestion cron
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=RiderOS/1.0
